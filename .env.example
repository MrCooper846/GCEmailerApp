# Email Campaign Manager - Environment Variables

# Google OAuth (Workspace Internal)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth2/callback

# Optional: legacy SMTP fallback (not used when Gmail OAuth is active)
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key

# HTML Template Path (optional - only if you want to use external template)
# HTML_PATH=C:/path/to/your/template.html
